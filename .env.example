# GitHub source to monitor
GITHUB_OWNER=OJWatson
GITHUB_REPO=ebolasim-tools-clean-pass
GITHUB_REF=main
GITHUB_VERSION_STRATEGY=commit
# Optional: token for higher GitHub API limits/private repos
GITHUB_TOKEN=

# Source selection
# github_archive (default): download exact GitHub snapshot for detected version
# local_dir: upload directly from LOCAL_SOURCE_DIR
SOURCE_MODE=github_archive
LOCAL_SOURCE_DIR=dummy_payload

# Backend selection
# token is the default/recommended Dropbox backend
DROPBOX_BACKEND=token
# local is the default/recommended Gmail backend
GMAIL_BACKEND=local
# send (default) or draft
GMAIL_ACTION=send

# Dropbox target (used by all Dropbox backends)
DROPBOX_TARGET_PATH=/github-dropbox-refresh-lite
DROPBOX_PERMANENT_DELETE=true
DROPBOX_FORCE_NEW_SHARE_LINK=true

# Dropbox token backend (recommended)
DROPBOX_ACCESS_TOKEN=

# Gmail notification target
GMAIL_TO=oj.watson92@gmail.com
GMAIL_SUBJECT_PREFIX=[Dropbox Refresh]

# Gmail local OAuth backend (GMAIL_BACKEND=local)
GMAIL_CLIENT_SECRET_FILE=secrets/google_client_secret.json
GMAIL_TOKEN_FILE=.state/gmail_token.json

# Optional Maton config (only for DROPBOX_BACKEND=maton and/or GMAIL_BACKEND=maton)
# Set one of MATON_API_KEY or MATON_API_KEY_FILE.
# MATON_API_KEY also accepts OpenClaw-style env://file/absolute/path pointers.
MATON_API_KEY=
MATON_API_KEY_FILE=
MATON_GATEWAY_BASE_URL=https://gateway.maton.ai
MATON_DROPBOX_CONNECTION=
MATON_GOOGLE_MAIL_CONNECTION=
