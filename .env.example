# GitHub source to monitor
GITHUB_OWNER=OJWatson
GITHUB_REPO=ebolasim-tools-clean-pass
GITHUB_REF=main
GITHUB_VERSION_STRATEGY=commit
# Optional: token for higher GitHub API limits
GITHUB_TOKEN=

# Local source folder to upload to Dropbox (inside this repo)
LOCAL_SOURCE_DIR=dummy_payload

# Dropbox target
DROPBOX_ACCESS_TOKEN=
DROPBOX_TARGET_PATH=/github-dropbox-refresh-lite
DROPBOX_PERMANENT_DELETE=true
DROPBOX_FORCE_NEW_SHARE_LINK=true

# Gmail draft output
GMAIL_TO=oj.watson92@gmail.com
GMAIL_SUBJECT_PREFIX=[Dropbox Refresh]
GMAIL_CLIENT_SECRET_FILE=secrets/google_client_secret.json
GMAIL_TOKEN_FILE=.state/gmail_token.json
